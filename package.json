{
  "name": "next-js-boilerplate",
  "version": "3.55.3",
  "author": "Ixartz (https://github.com/ixartz)",
  "scripts": {
    "dev:spotlight": "spotlight-sidecar",
    "dev:next": "next dev",
    "dev": "run-p dev:*",
    "build": "next build",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit --pretty",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "commit": "cz",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -c production -- drizzle-kit migrate",
    "db:studio": "dotenv -c production -- drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:serve": "http-server storybook-static --port 6006 --silent",
    "serve-storybook": "run-s storybook:*",
    "test-storybook:ci": "start-server-and-test serve-storybook http://127.0.0.1:6006 test-storybook",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/localizations": "^4.7.0",
    "@clerk/nextjs": "^7.4.2",
    "@designbycode/tailwindcss-text-stroke": "^1.3.0",
    "@electric-sql/pglite": "^0.2.2",
    "@hookform/resolvers": "5.4.0",
    "@logtail/pino": "^0.5.0",
    "@react-spring/web": "^10.1.0",
    "@sentry/nextjs": "10.55.0",
    "@spotlightjs/spotlight": "^2.3.1",
    "@t3-oss/env-nextjs": "0.13.11",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.8.1",
    "@types/react-dom": "^19.2.3",
    "classnames": "^2.5.1",
    "drizzle-orm": "0.45.2",
    "motion": "^12.8.0",
    "next": "16.2.6",
    "next-intl": "4.13.0",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.52.2",
    "react-icons": "^5.3.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@commitlint/cz-commitlint": "^19.4.0",
    "@eslint-react/eslint-plugin": "^5.8.7",
    "@faker-js/faker": "^8.4.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@next/eslint-plugin-next": "^16.2.6",
    "@percy/cli": "1.29.2",
    "@percy/playwright": "^1.0.6",
    "@playwright/test": "^1.46.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-links": "^10.4.1",
    "@storybook/addon-onboarding": "^10.4.1",
    "@storybook/nextjs-vite": "10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.4.1",
    "@types/pg": "^8.11.6",
    "@types/react": "^19.2.15",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/expect": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "checkly": "8.5.0",
    "commitizen": "4.3.1",
    "cross-env": "^10.1.0",
    "cssnano": "^8.0.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-jest-dom": "^5.4.0",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-storybook": "10.4.1",
    "eslint-plugin-tailwindcss": "^3.17.4",
    "eslint-plugin-testing-library": "^7.16.2",
    "http-server": "^14.1.1",
    "husky": "^9.1.4",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.10",
    "rimraf": "^6.0.1",
    "semantic-release": "^25.0.3",
    "start-server-and-test": "^2.0.5",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "5.9.3",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^4.1.7",
    "vitest-fail-on-console": "^0.7.0"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "lodash": "^4.17.21",
    "postcss": "$postcss",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  }
}
