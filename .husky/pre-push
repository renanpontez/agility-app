#!/usr/bin/env sh
# Block a push if any of these would have broken CI:
#   - ESLint errors
#   - TypeScript errors
#   - Failing unit tests
#   - A broken production build
#
# Skip with `SKIP_PREPUSH=1 git push` only when you know exactly what you're doing.

if [ "${SKIP_PREPUSH:-0}" = "1" ]; then
  echo "⚠ pre-push hook skipped via SKIP_PREPUSH=1"
  exit 0
fi

cd "$(dirname "$0")/.." || exit 1

set -e

echo "▸ Lint…"
npm run lint --silent

echo "▸ Typecheck…"
npm run check-types --silent

echo "▸ Unit tests…"
npm test --silent

echo "▸ Production build…"
# Use dummy creds so the build doesn't fail on env validation.
CLERK_SECRET_KEY="${CLERK_SECRET_KEY:-sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx}" \
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="${NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY:-pk_test_cmVsYXhlZC10dXJrZXktNjcuY2xlcmsuYWNjb3VudHMuZGV2JA}" \
NEXT_PUBLIC_CLERK_SIGN_IN_URL="${NEXT_PUBLIC_CLERK_SIGN_IN_URL:-/sign-in}" \
NEXT_TELEMETRY_DISABLED=1 \
npm run build --silent > /tmp/agility-prepush-build.log 2>&1 || {
  echo ""
  echo "✘ Production build failed (see /tmp/agility-prepush-build.log)"
  tail -30 /tmp/agility-prepush-build.log
  exit 1
}

echo "✓ pre-push checks passed"
